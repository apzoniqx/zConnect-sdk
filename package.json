{
  "name": "zconnect-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "ZConnect SDK Monorepo - Modular TypeScript SDK for ZConnect API",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:packages": "pnpm -r --filter './packages/**' build",
    "clean": "pnpm -r --filter './packages/**' clean",
    "generate:types": "openapi-typescript openapi.json -o packages/core/src/types/openapi-generated.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "openapi-typescript": "^6.7.6",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}

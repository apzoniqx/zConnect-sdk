{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/listings" },
    { "path": "./packages/connections" },
    { "path": "./packages/transactions" },
    { "path": "./packages/kyc" },
    { "path": "./packages/wallet" },
    { "path": "./packages/organization" },
    { "path": "./packages/chat" },
    { "path": "./packages/sdk" }
  ]
}
